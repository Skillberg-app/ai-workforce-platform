// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

// SQLite for development, PostgreSQL for production.
// Connection URL is configured in prisma.config.ts
datasource db {
  provider = "sqlite"
}

model Project {
  id          String   @id @default(cuid())
  name        String
  clientName  String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  jobs Job[]
}

model Job {
  id          String   @id @default(cuid())
  projectId   String
  externalId  String?
  title       String
  description String?
  createdAt   DateTime @default(now())

  project          Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks            Task[]
  skills           Skill[]
  svalbardMatches  SvalbardJobMatch[]
}

model Task {
  id                String  @id @default(cuid())
  jobId             String
  name              String
  description       String?
  timeAllocationPct Float

  job                  Job                  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  svalbardSkillMatches SvalbardSkillMatch[]
}

model Skill {
  id    String @id @default(cuid())
  jobId String
  name  String
  level String

  job                  Job                  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  svalbardSkillMatches SvalbardSkillMatch[]
}

model SvalbardJobMatch {
  id           String @id @default(cuid())
  jobId        String
  svalbardId   String
  svalbardName String
  confidence   Float
  status       String @default("pending") // pending | accepted | rejected

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model SvalbardSkillMatch {
  id                String @id @default(cuid())
  skillId           String
  taskId            String
  svalbardSkillId   String
  svalbardSkillName String
  confidence        Float
  status            String @default("pending") // pending | accepted | rejected

  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)
  task  Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
}
